API_PORT=4000
CORS_ORIGIN=http://localhost:3000
VITE_API_BASE_URL=http://localhost:4000

# Multi-Model AI Gateway providers
# Add your own valid API keys. Do not commit real secrets to GitHub.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=

# Local model support
# Example: run Ollama locally, then set this to http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Optional model overrides
OPENAI_DEFAULT_MODEL=gpt-4o-mini
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-latest
XAI_DEFAULT_MODEL=grok-2-latest
OLLAMA_DEFAULT_MODEL=llama3.1

# Private admin-only billing providers
# Keep real values only in .env. Never expose these in frontend code or commit real secrets.
BILLING_MODE=test
BILLING_PROVIDER=stripe

# Stripe placeholders
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# PayPal placeholders
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENVIRONMENT=sandbox
